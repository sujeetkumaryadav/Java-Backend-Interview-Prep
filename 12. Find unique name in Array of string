Method-2: using HashMap in O(n)

import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	
	String name[]={"java","selenium","java","test"};
	HashMap<String,Integer>map=new HashMap<>();
	
	for(String str:name){
	    map.put(str,map.getOrDefault(str,0)+1);
	    
	}
	for(String str: name){
	    if(map.get(str)==1)
	    System.out.println(str);
	}
	}
}
