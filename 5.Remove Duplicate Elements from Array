import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		int arr[]={10,20,40,10,30,20,40,40};
		
		HashSet<Integer>set=new HashSet<>();
		
		for(int x:arr){
		    if(!set.contains(x)){
		        System.out.print(x+" ");
		        set.add(x);
		    }
		}
		
	}
}
