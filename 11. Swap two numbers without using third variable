import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	int a=20,b=30;
	System.out.println("Before Swap: a="+a+" b="+b);
	
	 a=a+b;
	 b=a-b;
	 a=a-b;
	 
	 System.out.println("After Swap: a="+a+" b="+b);
	
	}
}

Output:
Before Swap: a=20 b=30
After Swap: a=30 b=20

