Method-2: Bubble Sort

import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		int arr[]={1,3,2,6,4,5};
		int temp;
		for(int i=0;i<arr.length;i++){
		    for(int j=0;j<arr.length-1-i;j++){
		        if(arr[j]>arr[j+1]){
		            temp=arr[j];
		            arr[j]=arr[j+1];
		            arr[j+1]=temp;
		        }
		    }
		}
		
		for(int x:arr){
		    System.out.print(x+" ");
		}
	
	}
}
