Method-2: Using LinkedHashSet in O(n)

import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	String str="programming";
	LinkedHashSet<Character>set=new LinkedHashSet<>();
	for(char ch: str.toCharArray()){
	    set.add(ch);
	}
	for(char c:set){
	    System.out.print(c);
	}
	}
}

