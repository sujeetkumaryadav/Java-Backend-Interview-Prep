Method:1 Exchange Sort

import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		int arr[]={1,3,2,6,4,5};
		int temp;
		for(int i=0;i<arr.length;i++){
		    for(int j=i+1;j<arr.length;j++){
		        if(arr[i]>arr[j]){
		            temp=arr[i];
		            arr[i]=arr[j];
		            arr[j]=temp;
		        }
		    }
		}
		
		for(int x:arr){
		    System.out.print(x+" ");
		}
	
	}
}

Input: {1,3,2,6,4,5}
Output: 1 2 3 4 5 6 
