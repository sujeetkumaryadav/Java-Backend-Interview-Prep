Method-2: Using HashSet in O(n)

import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		String str="java is java program java";
		
		String words[]=str.split(" ");
		
		HashSet<String>set=new HashSet<>();
		HashSet<String>dupSet=new HashSet<>();
		
		for(String st:words){
		    
		    if(!set.add(st)){
		       dupSet.add(st);
		    }
		}
		for(String str2:dupSet){
		    System.out.print(str2+" ");
		}
	}
}

Input: java is java program java
Output: java
