	{
		String str="sujeetu";
		
		int arr[]=new int[26];
		
		for(int i=0;i<str.length();i++){
		    
		    arr[str.charAt(i)-'a']++;
		}
		
		for(int i=0;i<26;i++){
		    if(arr[i]>1)
		    System.out.print((char)(i+'a')+" ");
		}
		   
	}
}

